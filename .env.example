DDNS_ADMIN_PASSWORD=change-me-long-random-admin-password
DDNS_SESSION_SECRET=change-me-long-random-session-secret
DDNS_PUBLIC_BASE_URL=https://ddns.example.net
DDNS_HOSTNAME_SUFFIX=ddns.example.net
DDNS_DATABASE=/data/ddns.sqlite3
DDNS_DNS_PROVIDER=cloudflare
DDNS_DNS_ZONES=ddns.example.net
DDNS_REQUIRE_DNS_PROVIDER=1
DDNS_CLOUDFLARE_API_TOKEN=change-me-cloudflare-token
DDNS_CLOUDFLARE_ZONE_ID=change-me-cloudflare-zone-id
DDNS_TTL=60
DDNS_RATE_LIMIT_PER_MINUTE=60
DDNS_CLEANUP_CHALLENGE_HOURS=72
DDNS_TRUSTED_PROXY_IPS=127.0.0.1,::1
